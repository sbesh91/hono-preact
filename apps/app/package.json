{
  "name": "app",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development vite --force",
    "build": "NODE_ENV=production vite build --mode client && vite build",
    "visualize": "NODE_ENV=production vite build --mode visualizer",
    "updates": "npx npm-check-updates -i --format group",
    "deploy": "wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@hono-preact/iso": "workspace:*",
    "@hono-preact/server": "workspace:*",
    "@shikijs/rehype": "^4.0.2",
    "dotenv": "^17.4.2",
    "hono": "^4.12.14",
    "hoofd": "^1.7.3",
    "preact": "^10.29.1",
    "preact-iso": "github:preactjs/preact-iso#v3",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat",
    "react-is": "npm:@preact/compat"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/types": "^7.29.0",
    "@hono-preact/vite": "workspace:*",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@hono/node-server": "^1.19.14",
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.25.1",
    "@mdx-js/rollup": "^3.1.1",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "magic-string": "^0.30.21",
    "miniflare": "^4.20260415.0",
    "postcss": "^8.5.10",
    "preact-render-to-string": "^6.6.7",
    "prettier": "^3.8.3",
    "remark-gfm": "^4.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.99.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "wrangler": "^4.83.0"
  }
}
