{
  "name": "site",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development vite --force",
    "build": "NODE_ENV=production vite build",
    "visualize": "NODE_ENV=production VISUALIZE=1 vite build --mode client",
    "updates": "npx npm-check-updates -i --format group",
    "deploy": "wrangler deploy -c dist/hono_preact/wrangler.json",
    "deploy:upload": "wrangler versions upload -c dist/hono_preact/wrangler.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "hono-preact-ui": "workspace:*",
    "hono-preact": "workspace:*",
    "@shikijs/rehype": "^4.0.2",
    "hono": "^4.12.14",
    "hoofd": "^1.7.3",
    "lucide-preact": "^1.14.0",
    "preact": "^10.29.1",
    "preact-iso": "github:preactjs/preact-iso#v3",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat",
    "react-is": "npm:@preact/compat"
  },
  "devDependencies": {
    "@babel/parser": "^8.0.0",
    "@babel/types": "^8.0.0",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@cloudflare/vite-plugin": "^1.37.1",
    "@hono/node-server": "^1.19.14",
    "@mdx-js/rollup": "^3.1.1",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "magic-string": "^0.30.21",
    "postcss": "^8.5.10",
    "preact-render-to-string": "^6.6.7",
    "prettier": "^3.8.3",
    "remark-gfm": "^4.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.99.0",
    "tailwindcss": "^4.2.2",
    "typescript": "*",
    "vite": "*",
    "wrangler": "^4.92.0"
  }
}
