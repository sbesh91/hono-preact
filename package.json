{
  "name": "hono-preact-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --filter site run dev",
    "build": "pnpm --filter '@hono-preact/*' --filter hono-preact --filter hono-preact-ui build && pnpm --filter site build && node scripts/emit-size-probes.mjs",
    "deploy": "pnpm --filter site run deploy",
    "deploy:upload": "pnpm --filter site run deploy:upload",
    "preview": "pnpm --filter site run preview",
    "visualize": "pnpm --filter site run visualize",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:types": "vitest run --typecheck.only",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,mjs,json}\" \"apps/**/src/**/*.{ts,tsx,mdx}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,mjs,json}\" \"apps/**/src/**/*.{ts,tsx,mdx}\"",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run",
    "release:ui": "node scripts/release-ui.mjs",
    "release:ui:dry": "node scripts/release-ui.mjs --dry-run",
    "measure:lighthouse": "node scripts/measure-lighthouse.mjs",
    "wt:setup": "bash scripts/worktree-setup.sh"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.27.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "typescript": "*",
    "vitest": "^4.1.4"
  }
}
