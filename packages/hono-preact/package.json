{
  "name": "hono-preact",
  "version": "0.10.1",
  "description": "Hono on the edge, Preact in the browser, manifest driven routes, typed RPC, streaming everywhere.",
  "keywords": [
    "hono",
    "preact",
    "framework",
    "ssr",
    "streaming",
    "rpc",
    "cloudflare-workers",
    "vite"
  ],
  "homepage": "https://framework.sbesh.com",
  "bugs": {
    "url": "https://github.com/sbesh91/hono-preact/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sbesh91/hono-preact.git",
    "directory": "packages/hono-preact"
  },
  "license": "MIT",
  "author": "Steven Beshensky",
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./page": {
      "types": "./dist/page.d.ts",
      "import": "./dist/page.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./adapter-cloudflare": {
      "types": "./dist/adapter-cloudflare.d.ts",
      "import": "./dist/adapter-cloudflare.js"
    },
    "./adapter-node": {
      "types": "./dist/adapter-node.d.ts",
      "import": "./dist/adapter-node.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    },
    "./internal/runtime": {
      "types": "./dist/internal-runtime.d.ts",
      "import": "./dist/internal-runtime.js"
    },
    "./server/internal/runtime": {
      "types": "./dist/server-internal-runtime.d.ts",
      "import": "./dist/server-internal-runtime.js"
    },
    "./server/internal/cloudflare": {
      "types": "./dist/server-internal-cloudflare.d.ts",
      "import": "./dist/server-internal-cloudflare.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/consolidate.mjs",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc && node scripts/consolidate.mjs"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "@preact/preset-vite": "^2.10.5",
    "magic-string": "^0.30.21"
  },
  "peerDependencies": {
    "@cloudflare/vite-plugin": "^1.37.1",
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.1",
    "hono": ">=4.0.0",
    "hoofd": ">=1.0.0",
    "preact": ">=10.0.0",
    "preact-iso": ">=2.11.0",
    "preact-render-to-string": ">=6.0.0",
    "vite": ">=6.0.0",
    "wrangler": "^4.92.0"
  },
  "peerDependenciesMeta": {
    "@cloudflare/vite-plugin": {
      "optional": true
    },
    "@hono/node-server": {
      "optional": true
    },
    "@hono/node-ws": {
      "optional": true
    },
    "wrangler": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260515.0",
    "@hono-preact/iso": "workspace:*",
    "@hono-preact/server": "workspace:*",
    "@hono-preact/vite": "workspace:*",
    "typescript": "*"
  },
  "sideEffects": false
}
